{
  "name": "mochis-daily-quest",
  "version": "1.0.0",
  "description": "A retro kawaii Tamagotchi-style daily to-do app",
  "main": "main.js",
  "author": "Mochi Studio",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --dir",
    "build:dmg": "electron-builder --mac dmg",
    "pack": "electron-builder --dir"
  },
  "keywords": [],
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.mochi.dailyquest",
    "productName": "Mochi's Daily Quest",
    "copyright": "Copyright © 2025 Mochi Studio",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "darkModeSupport": false,
      "icon": "assets/AppIcon.iconset"
    },
    "dmg": {
      "title": "Mochi's Daily Quest",
      "backgroundColor": "#E8D5F5"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "assets/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
